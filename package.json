{
  "name": "@atorresg/weather-mcp",
  "version": "1.0.1",
  "mcpName": "io.github.atorresg/weather-mcp",
  "description": "Weather MCP Server, giving LLMs weather forecast capabilities (current conditions, daily forecast, hourly data) via Open-Meteo (free, no API key required).",
  "private": false,
  "type": "module",
  "keywords": [
    "AI",
    "LLM",
    "MCP",
    "ModelContextProtocol",
    "Weather MCP Server",
    "Weather",
    "Forecast",
    "Open-Meteo"
  ],
  "author": "atorresg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atorresg/weather-mcp.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "weather-mcp": "build/index.cjs"
  },
  "files": [
    "dist/**",
    "build/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "cjs",
      "esm"
    ],
    "splitting": false,
    "clean": true,
    "dts": true,
    "sourcemap": true
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "build:bundle": "node build.mjs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^8.56.0",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.0.0"
  }
}
